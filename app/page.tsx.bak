import { motion } from 'framer-motion';
import { Typewriter, CodeSnippet } from '@/components/hero/Typewriter';
import { Timeline } from '@/components/hero/Timeline';
import { SkillCloud } from '@/components/hero/SkillCloud';
import { NavLinks } from '@/components/hero/NavLinks';
import { profile, experiences, skills } from '@/lib/config';

const introCode = `const me = {
  role: "${profile.role}",
  passion: "build products from 0 to 1",
  now: "exploring AI × Product",
  location: "China",
  available: true
}`;

export default function Home() {
  return (
    <main className="min-h-screen bg-background text-foreground">
      {/* Hero Section */}
      <section className="min-h-screen px-4 py-20 md:px-8">
        <div className="container mx-auto max-w-6xl">
          <div className="grid gap-12 lg:grid-cols-2">
            {/* Left: Intro */}
            <div className="flex flex-col justify-center space-y-8">
              <div
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                transition={{ duration: 0.6 }}
              >
                <div className="mb-4 font-mono text-terminal-green text-sm">~/whoami</div>
                <h1 className="mb-4 text-4xl font-bold md:text-6xl">
                  <span className="gradient-text">{profile.name}</span>
                </h1>
                <Typewriter
                  text={profile.tagline}
                  speed={80}
                  className="text-xl text-gray-400"
                />
              </motion.div>

              <motion.p
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                transition={{ duration: 0.6, delay: 0.2 }}
                className="text-gray-400 leading-relaxed"
              >
                {profile.bio}
              </motion.p>

              <div
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                transition={{ duration: 0.6, delay: 0.4 }}
              >
                <CodeSnippet code={introCode} />
              </motion.div>

              <NavLinks />
            </div>

            {/* Right: Visual / Stats */}
            <div
              className="flex flex-col justify-center space-y-8"
              initial={{ opacity: 0, x: 20 }}
              animate={{ opacity: 1, x: 0 }}
              transition={{ duration: 0.8 }}
            >
              {/* Stats */}
              <div className="grid grid-cols-2 gap-4">
                {[
                  { label: 'Years Experience', value: '5+' },
                  { label: 'Projects Built', value: '20+' },
                  { label: 'Open Source', value: '10+' },
                  { label: 'Articles Published', value: '30+' },
                ].map((stat, i) => (
                  <div
                    key={i}
                    className="rounded-lg bg-code-bg p-4"
                    initial={{ opacity: 0, y: 10 }}
                    animate={{ opacity: 1, y: 0 }}
                    transition={{ duration: 0.4, delay: 0.5 + i * 0.1 }}
                  >
                    <div className="text-2xl font-bold text-terminal-green">{stat.value}</div>
                    <div className="text-sm text-gray-400">{stat.label}</div>
                  </motion.div>
                ))}
              </div>

              {/* Status indicator */}
              <div
                className="flex items-center gap-3 rounded-lg bg-code-bg p-4"
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                transition={{ duration: 0.6, delay: 0.8 }}
              >
                <div className="h-2 w-2 rounded-full bg-terminal-green animate-pulse" />
                <div className="font-mono text-sm">
                  <span className="text-terminal-green">STATUS:</span>{' '}
                  <span className="text-gray-300">Open to opportunities</span>
                </div>
              </motion.div>
            </motion.div>
          </div>
        </div>
      </section>

      {/* Experience Section */}
      <section className="border-t border-terminal-border px-4 py-16 md:px-8">
        <div className="container mx-auto max-w-4xl">
          <motion.h2
            className="mb-12 font-mono text-terminal-green text-sm"
            initial={{ opacity: 0 }}
            whileInView={{ opacity: 1 }}
            viewport={{ once: true }}
          >
            ~/experience
          </motion.h2>
          <Timeline experiences={experiences} />
        </div>
      </section>

      {/* Skills Section */}
      <section className="border-t border-terminal-border px-4 py-16 md:px-8">
        <div className="container mx-auto max-w-4xl">
          <motion.h2
            className="mb-12 font-mono text-terminal-green text-sm"
            initial={{ opacity: 0 }}
            whileInView={{ opacity: 1 }}
            viewport={{ once: true }}
          >
            ~/skills
          </motion.h2>
          <SkillCloud skills={skills} />
        </div>
      </section>
    </main>
  );
}
