# Site Configuration
NEXT_PUBLIC_SITE_URL=https://alexlabx.com

# Agent API Keys (必须配置)
# OpenRouter API Key - 用于 AI Agent 对话功能
OPENROUTER_API_KEY=your-openrouter-api-key

# OpenRouter Model - 可选，不配置则使用默认模型
# 常用模型: anthropic/claude-3.5-sonnet, openai/gpt-4o, google/gemini-pro-1.5
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Analytics (Umami - 可选)
NEXT_PUBLIC_UMAMI_ID=your-umami-tracking-id
NEXT_PUBLIC_UMAMI_URL=https://analytics.your-domain.com

# GitHub Token (可选 - 用于展示项目信息)
NEXT_PUBLIC_GITHUB_TOKEN=your-github-token